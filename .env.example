# Vercel Postgres (Neon) - auto-set by `vercel env pull`
POSTGRES_URL=
DATABASE_URL=

# Resend - email sending for contact form and newsletter
RESEND_API_KEY=

# Newsletter - sending address and site URL
# NEWSLETTER_FROM_EMAIL must use a domain verified in Resend
NEWSLETTER_FROM_EMAIL=
SITE_URL=

# Vercel Blob - file/image storage
BLOB_READ_WRITE_TOKEN=

# ntfy - push notification topic for new inquiries (self-hosted, TLS + bearer auth)
NTFY_INQUIRY_URL=
NTFY_INQUIRY_TOKEN=

# Umami - self-hosted analytics at stats.valdez.is (website ID is public-by-design)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
