# Vercel Postgres (Neon) - auto-set by `vercel env pull`
POSTGRES_URL=
DATABASE_URL=

# Resend - email sending for contact form
RESEND_API_KEY=

# Vercel Blob - file/image storage
BLOB_READ_WRITE_TOKEN=

# ntfy - push notification topic for new inquiries (lean payload, never include sensitive data)
NTFY_INQUIRY_URL=
